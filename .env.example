PORT=4000

# Signs/verifies JWTs in src/middleware/guard.js — required for guard to
# work at all (it throws a 500 if unset, on purpose, rather than silently
# accepting unsigned tokens).
JWT_SECRET=

# Not yet consumed — src/db/client.js is a stub until this exists.
# Matches the local Postgres from ../docker-compose.yml once it's running:
# postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@localhost:5432/workbridge_db
DATABASE_URL=
